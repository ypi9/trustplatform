# ──────────────────────────────────────────────
# TrustPlatform Auth Service — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Spring Boot reads these automatically if you use
# a .env plugin, or export them in your shell.
# ──────────────────────────────────────────────

# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=authdb
DB_USERNAME=your_pg_username
DB_PASSWORD=

# ── JWT ──
JWT_SECRET=your-256-bit-secret-key-here
JWT_EXPIRATION=3600000

# ── AWS ──
AWS_REGION=us-east-2
AWS_S3_BUCKET=your-private-s3-bucket
# Authentication: use ONE of these approaches
# Option A: explicit keys (not recommended for production)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Option B: use a named profile (preferred for local dev)
# AWS_PROFILE=trustplatform

# ── Optional bootstrap admin (deploy/test only) ──
BOOTSTRAP_ADMIN_EMAIL=

# ── Spring Security (basic auth defaults) ──
SPRING_SECURITY_USER=admin
SPRING_SECURITY_PASS=admin
