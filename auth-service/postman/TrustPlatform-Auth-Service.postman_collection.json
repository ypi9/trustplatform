                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select auth-service/demo/sample-document.pdf"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/files/upload",
              "host": ["{{baseUrl}}"],
              "path": ["files", "upload"]
