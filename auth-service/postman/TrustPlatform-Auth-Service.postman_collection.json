{
  "info": {
    "name": "TrustPlatform Auth Service",
    "description": "API collection for the TrustPlatform authentication service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "fileUrl",
      "value": "uploads/2026/04/21/your-uploaded-object.png",
      "type": "string"
    },
    {
      "key": "documentKey",
      "value": "uploads/2026/04/21/your-uploaded-object.png",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "description": "Register a new user with email and password"
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with email and password"
          },
          "response": []
        },
        {
          "name": "Me (no token)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Get current user info without token (should return 401)"
          },
          "response": []
        },
        {
          "name": "Me (invalid token)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalidtoken"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Get current user info with invalid token (should return 401)"
          },
          "response": []
        },
        {
          "name": "Me (valid token)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Get current user info with valid token (set accessToken variable from login response)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Verification",
      "item": [
        {
          "name": "Submit Verification (success)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentKey\": \"{{documentKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/verification/submit",
              "host": ["{{baseUrl}}"],
              "path": ["verification", "submit"]
            },
            "description": "Submit a verification request using the S3 object key returned by /files/upload in documentKey (expects 200 with requestId + PENDING)."
          },
          "response": []
        },
        {
          "name": "Submit Verification (missing documentKey -> 400)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentKey\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/verification/submit",
              "host": ["{{baseUrl}}"],
              "path": ["verification", "submit"]
            },
            "description": "Submit without a valid S3 object key in documentKey (expects 400 Bad Request)."
          },
          "response": []
        },
        {
          "name": "Submit Verification (already pending/verified -> 409)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentKey\": \"{{documentKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/verification/submit",
              "host": ["{{baseUrl}}"],
              "path": ["verification", "submit"]
            },
            "description": "Re-submit when state is PENDING or VERIFIED (expects 409 Conflict)."
          },
          "response": []
        },
        {
          "name": "Get Verification Status",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/verification/status",
              "host": ["{{baseUrl}}"],
              "path": ["verification", "status"]
            },
            "description": "Get current verification level and latest request details (expects 200)."
          },
          "response": []
        },
        {
          "name": "Review Verification (as USER -> 403)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"PASTE_REQUEST_ID_HERE\",\n  \"decision\": \"APPROVED\",\n  \"reviewNotes\": \"Trying as regular user\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/verification/review",
              "host": ["{{baseUrl}}"],
              "path": ["verification", "review"]
            },
            "description": "Attempt to review as a regular USER (expects 403 Forbidden)."
          },
          "response": []
        },
        {
          "name": "Review Verification (approve)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"PASTE_REQUEST_ID_HERE\",\n  \"decision\": \"APPROVED\",\n  \"reviewNotes\": \"Document looks valid\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/verification/review",
              "host": ["{{baseUrl}}"],
              "path": ["verification", "review"]
            },
            "description": "Approve a pending verification request (expects 200 with VERIFIED level)."
          },
          "response": []
        },
        {
          "name": "Review Verification (reject)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"PASTE_REQUEST_ID_HERE\",\n  \"decision\": \"REJECTED\",\n  \"reviewNotes\": \"Document is blurry\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/verification/review",
              "host": ["{{baseUrl}}"],
              "path": ["verification", "review"]
            },
            "description": "Reject a pending verification request (expects 200 with REJECTED level)."
          },
          "response": []
        },
        {
          "name": "Review Verification (already reviewed -> 409)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"PASTE_REQUEST_ID_HERE\",\n  \"decision\": \"APPROVED\",\n  \"reviewNotes\": \"Trying again\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/verification/review",
              "host": ["{{baseUrl}}"],
              "path": ["verification", "review"]
            },
            "description": "Re-review an already reviewed request (expects 409 Conflict)."
          },
          "response": []
        },
        {
          "name": "List All Requests",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/verification/requests",
              "host": ["{{baseUrl}}"],
              "path": ["verification", "requests"]
            },
            "description": "List all verification requests, newest first."
          },
          "response": []
        },
        {
          "name": "List Requests (filter by PENDING)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/verification/requests?status=PENDING",
              "host": ["{{baseUrl}}"],
              "path": ["verification", "requests"],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING"
                }
              ]
            },
            "description": "List verification requests filtered by PENDING status."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Files",
      "item": [
        {
          "name": "Upload File (success)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select a PNG, JPG, or PDF file (max 5 MB)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/files/upload",
              "host": ["{{baseUrl}}"],
              "path": ["files", "upload"]
            },
            "description": "Upload a file to S3 (PNG, JPG, or PDF, max 5 MB). Returns bucket, objectKey, originalFilename, contentType, size, and fileUrl. Use objectKey as documentKey when submitting verification."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Upload returns S3 metadata\", function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.bucket).to.be.a(\"string\").and.not.empty;",
                  "  pm.expect(body.objectKey).to.be.a(\"string\").and.not.empty;",
                  "  pm.expect(body.originalFilename).to.be.a(\"string\").and.not.empty;",
                  "  pm.expect(body.contentType).to.be.oneOf([\"image/png\", \"image/jpeg\", \"application/pdf\"]);",
                  "  pm.expect(body.size).to.be.a(\"number\");",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "if (body.objectKey) {",
                  "  pm.collectionVariables.set(\"documentKey\", body.objectKey);",
                  "  pm.collectionVariables.set(\"fileUrl\", body.objectKey);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Upload File (no token -> 401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select any file"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/files/upload",
              "host": ["{{baseUrl}}"],
              "path": ["files", "upload"]
            },
            "description": "Upload without auth token (expects 401 Unauthorized)."
          },
          "response": []
        },
        {
          "name": "Upload File (invalid type -> 400)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select a non-allowed file type (e.g. .txt, .exe)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/files/upload",
              "host": ["{{baseUrl}}"],
              "path": ["files", "upload"]
            },
            "description": "Upload a file with disallowed content type (expects 400 Bad Request)."
          },
          "response": []
        }
      ]
    }
  ]
}
