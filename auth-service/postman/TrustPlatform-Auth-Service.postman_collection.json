        {
          "name": "Upload User Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Upload succeeded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "if (body.objectKey) {",
                  "  pm.environment.set(\"documentKey\", body.objectKey);",
                  "  pm.environment.set(\"fileUrl\", body.fileUrl || body.objectKey);",
                  "}",
                  "if (body.requestId) {",
